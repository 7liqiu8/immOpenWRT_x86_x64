# Target Config（架构核心配置，保留）
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# Set Firmware Size（固件分区大小，保留）
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=960

# Firmware Type（固件格式核心配置，保留）
# CONFIG_GRUB_CONSOLE is not set
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_TARGZ=y
# CONFIG_VMDK_IMAGES is not set

# 硬件驱动（网卡/CPU/系统优化，保留）
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-igc=y
CONFIG_PACKAGE_kmod-r8169=y 
# CONFIG_PACKAGE_kmod-cpufreq is not set
# CONFIG_PACKAGE_cpufrequtils is not set
CONFIG_PACKAGE_irqbalance=y

# 仅保留 OpenClash 和 PassWall 核心插件
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-nf-tproxy=y
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Nftables_Transparent_Proxy=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Brook=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_NaiveProxy=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Client=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Server=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR_Libev_Server=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Trojan_GO=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_tuic_client=y
CONFIG_PACKAGE_trojan-plus=n

# 基础网络工具（保留核心，移除非必要）
CONFIG_PACKAGE_ping=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_nftables-json=y
CONFIG_PACKAGE_kmod-nft-extra=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_iperf3=y

# USB基础驱动 + 拨号设备驱动（保留，保障USB网卡/拨号功能）
CONFIG_PACKAGE_kmod-usb-core=y 
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_usbutils=y              
CONFIG_PACKAGE_kmod-usb-net-zyxel=y
CONFIG_PACKAGE_kmod-usb-net-asix=y
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=y
CONFIG_PACKAGE_kmod-usb-net=y          
CONFIG_PACKAGE_kmod-usb-net-rndis=y    
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y 
CONFIG_PACKAGE_rndis-tools=y         

# IPv6 支持（保留核心，保障网络兼容性）
CONFIG_PACKAGE_6in4=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_dnsmasq_full=y
CONFIG_PACKAGE_luci-proto-ppp=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-app-network=y
CONFIG_PACKAGE_firewall4-ipv6=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_luci-app-firewall=y
# CONFIG_PACKAGE_firewall is not set
CONFIG_PACKAGE_iproute2=y
CONFIG_PACKAGE_ping6=y
CONFIG_PACKAGE_tracepath6=y

# PPPoE 拨号核心组件（保留，保障宽带拨号）
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_pppd=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_ppp-mod-ipv6=y
CONFIG_PACKAGE_kmod-ppp=y
CONFIG_PACKAGE_kmod-pppoe=y
CONFIG_PACKAGE_kmod-pppox=y

# 精简工具/主题（仅保留基础工具，移除所有主题和非必要软件）
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano-plus=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_vim-fuller=y
